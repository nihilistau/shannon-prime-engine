# Cross-platform line-ending policy.
# Everything git-managed as text normalizes to LF in the repo AND on checkout.
# Prevents the Windows-CRLF / Linux-LF drift that made `git status` noisy.
* text=auto eol=lf

# Windows-specific scripts need CRLF to run correctly under cmd.exe / powershell.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Explicit text (belt-and-braces — auto-detect is reliable but these are load-bearing).
*.c    text
*.h    text
*.cpp  text
*.hpp  text
*.cu   text
*.py   text
*.md   text
*.sh   text
CMakeLists.txt text

# Binary files (never line-end convert).
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.mp4 binary
*.pdf binary
*.zip binary
*.7z  binary
*.tar binary
*.gz  binary
*.tgz binary
*.gguf binary
*.pt  binary
*.bin binary
*.so  binary
*.dll binary
*.dylib binary
*.exe binary
*.spv binary
